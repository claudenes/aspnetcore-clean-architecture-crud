@using Colorado.Application.Dtos
@model ClienteDto
@{
    ViewData["Title"] = "Novo Cliente";
    var tiposJson = ViewBag.TiposTelefoneJson as string ?? "[]";
}

<div class="d-flex align-items-center mb-4 gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h2 class="mb-0"><i class="bi bi-person-plus text-danger"></i> Novo Cliente</h2>
</div>

<form id="frmCliente" novalidate>
    @Html.AntiForgeryToken()

    <div class="row g-3">
        <!-- Dados principais -->
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-danger text-white fw-bold">
                    <i class="bi bi-person-badge"></i> Dados Cadastrais
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-2">
                            <label class="form-label">Tipo Pessoa *</label>
                            <select id="TipoPessoa" name="TipoPessoa" class="form-select" required>
                                <option value="F">Física</option>
                                <option value="J">Jurídica</option>
                            </select>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Razão Social *</label>
                            <input type="text" id="RazaoSocial" name="RazaoSocial" class="form-control" required maxlength="200" />
                            <div class="invalid-feedback">Razão Social é obrigatória.</div>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Nome Fantasia</label>
                            <input type="text" id="NomeFantasia" name="NomeFantasia" class="form-control" maxlength="200" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Documento (CPF/CNPJ) *</label>
                            <input type="text" id="Documento" name="Documento" class="form-control" required maxlength="18" />
                            <div class="invalid-feedback">Documento é obrigatório.</div>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Endereço</label>
                            <input type="text" id="Endereco" name="Endereco" class="form-control" maxlength="300" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Complemento</label>
                            <input type="text" id="Complemento" name="Complemento" class="form-control" maxlength="100" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Bairro</label>
                            <input type="text" id="Bairro" name="Bairro" class="form-control" maxlength="100" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Cidade</label>
                            <input type="text" id="Cidade" name="Cidade" class="form-control" maxlength="100" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">CEP</label>
                            <input type="text" id="CEP" name="CEP" class="form-control" maxlength="9" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">UF</label>
                            <input type="text" id="UF" name="UF" class="form-control" maxlength="2" style="text-transform:uppercase" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Telefones -->
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-danger text-white fw-bold d-flex justify-content-between">
                    <span><i class="bi bi-telephone"></i> Telefones</span>
                    <button type="button" id="btnAddTelefone" class="btn btn-sm btn-light">
                        <i class="bi bi-plus"></i> Adicionar
                    </button>
                </div>
                <div class="card-body">
                    <table class="table table-sm" id="tblTelefones">
                        <thead>
                            <tr>
                                <th>Número *</th>
                                <th>Tipo *</th>
                                <th>Operadora</th>
                                <th>Ativo</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="telefoneRows"></tbody>
                    </table>
                    <small class="text-muted">Adicione ao menos um telefone.</small>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-danger" id="btnSalvar">
            <i class="bi bi-check-circle"></i> Salvar
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
    </div>

    <div id="alertMsg" class="mt-3" style="display:none"></div>
</form>

@section Scripts {
    <script>
        var tiposTelefone = @Html.Raw(tiposJson);
        var token = $('input[name="__RequestVerificationToken"]').val();

        function buildTiposOptions(selected) {
            return tiposTelefone.map(function (t) {
                var sel = (t.codigoTipoTelefone === selected) ? 'selected' : '';
                return '<option value="' + t.codigoTipoTelefone + '" ' + sel + '>' + t.descricaoTipoTelefone + '</option>';
            }).join('');
        }

        function addTelefoneRow(tel) {
            tel = tel || {};
            var idx = $('#telefoneRows tr').length;
            var row = '<tr>' +
                '<td><input type="text" class="form-control form-control-sm tel-numero" required maxlength="20" value="' + (tel.numeroTelefone || '') + '" /></td>' +
                '<td><select class="form-select form-select-sm tel-tipo">' + buildTiposOptions(tel.codigoTipoTelefone) + '</select></td>' +
                '<td><input type="text" class="form-control form-control-sm tel-operadora" maxlength="50" value="' + (tel.operadora || '') + '" /></td>' +
                '<td class="text-center"><input type="checkbox" class="form-check-input tel-ativo" ' + (tel.ativo !== false ? 'checked' : '') + ' /></td>' +
                '<td><button type="button" class="btn btn-sm btn-outline-danger btn-rm-tel"><i class="bi bi-x"></i></button></td>' +
                '</tr>';
            $('#telefoneRows').append(row);
        }

        $('#btnAddTelefone').on('click', function () { addTelefoneRow(); });
        $(document).on('click', '.btn-rm-tel', function () { $(this).closest('tr').remove(); });

        function collectTelefones() {
            var list = [];
            $('#telefoneRows tr').each(function () {
                list.push({
                    numeroTelefone: $(this).find('.tel-numero').val().trim(),
                    // codigoTipoTelefone: parseInt($(this).find('.tel-tipo').val()),
                    codigoTipoTelefone: 2,
                    operadora: $(this).find('.tel-operadora').val().trim() || null,
                    ativo: $(this).find('.tel-ativo').is(':checked'),
                    usuarioInsercao: 'sistema'
                });
            });
            return list;
        }

        $('#frmCliente').on('submit', function (e) {
            e.preventDefault();
            var payload = {
                razaoSocial: $('#RazaoSocial').val().trim(),
                nomeFantasia: $('#NomeFantasia').val().trim(),
                tipoPessoa: $('#TipoPessoa').val(),
                documento: $('#Documento').val().trim(),
                endereco: $('#Endereco').val().trim() || null,
                complemento: $('#Complemento').val().trim() || null,
                bairro: $('#Bairro').val().trim() || null,
                cidade: $('#Cidade').val().trim() || null,
                cep: $('#CEP').val().trim() || null,
                uf: $('#UF').val().trim().toUpperCase() || null,
                usuarioInsercao: 'sistema',
                telefones: collectTelefones()
            };

            if (!payload.razaoSocial || !payload.documento) {
                showAlert('danger', 'Preencha os campos obrigatórios.');
                return;
            }

            $('#btnSalvar').prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Salvando...');

            $.ajax({
                url: '/Clientes/Create',
                type: 'POST',
                contentType: 'application/json; charset=utf-8',
                data: JSON.stringify(payload),
                success: function (res) {
                    showAlert('success', 'Cliente salvo com sucesso!');
                    setTimeout(function () { window.location.href = '/Clientes'; }, 1000);
                },
                error: function (xhr) {
                    showAlert('danger', 'Erro ao salvar: ' + (xhr.responseJSON?.title || xhr.statusText));
                    $('#btnSalvar').prop('disabled', false).html('<i class="bi bi-check-circle"></i> Salvar');
                }
            });
        });

        function showAlert(type, msg) {
            $('#alertMsg').removeClass().addClass('alert alert-' + type).html(msg).show();
        }
    </script>
}
