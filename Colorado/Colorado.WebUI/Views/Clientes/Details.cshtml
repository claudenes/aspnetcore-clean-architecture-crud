@using Colorado.Application.Dtos
@model ClienteDto
@{
    ViewData["Title"] = "Detalhes do Cliente";
}

<div class="d-flex align-items-center mb-4 gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h2 class="mb-0"><i class="bi bi-person-lines-fill text-danger"></i> @Model.RazaoSocial</h2>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-danger text-white fw-bold">Dados Cadastrais</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Código</dt>
                    <dd class="col-sm-8">@Model.CodigoCliente</dd>
                    <dt class="col-sm-4">Razão Social</dt>
                    <dd class="col-sm-8">@Model.RazaoSocial</dd>
                    <dt class="col-sm-4">Nome Fantasia</dt>
                    <dd class="col-sm-8">@Model.NomeFantasia</dd>
                    <dt class="col-sm-4">Tipo</dt>
                    <dd class="col-sm-8">
                        <span class="badge @(Model.TipoPessoa == "F" ? "bg-info" : "bg-warning text-dark")">
                            @(Model.TipoPessoa == "F" ? "Pessoa Física" : "Pessoa Jurídica")
                        </span>
                    </dd>
                    <dt class="col-sm-4">Documento</dt>
                    <dd class="col-sm-8">@Model.Documento</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-secondary text-white fw-bold">Endereço</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Endereço</dt>
                    <dd class="col-sm-8">@Model.Endereco @Model.Complemento</dd>
                    <dt class="col-sm-4">Bairro</dt>
                    <dd class="col-sm-8">@Model.Bairro</dd>
                    <dt class="col-sm-4">Cidade/UF</dt>
                    <dd class="col-sm-8">@Model.Cidade / @Model.UF</dd>
                    <dt class="col-sm-4">CEP</dt>
                    <dd class="col-sm-8">@Model.CEP</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-secondary text-white fw-bold">Telefones</div>
            <div class="card-body p-0">
                @if (Model.Telefones.Any())
                {
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Número</th>
                                <th>Tipo</th>
                                <th>Operadora</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.Telefones)
                            {
                                <tr>
                                    <td>@t.NumeroTelefone</td>
                                    <td><span class="badge bg-secondary">@t.TipoTelefone.DescricaoTipoTelefone</span></td>
                                    <td>@t.Operadora</td>
                                    <td>
                                        <span class="badge @(t.Ativo ? "bg-success" : "bg-secondary")">
                                            @(t.Ativo ? "Ativo" : "Inativo")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted p-3 mb-0">Nenhum telefone cadastrado.</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.CodigoCliente" class="btn btn-primary">
        <i class="bi bi-pencil"></i> Editar
    </a>
    <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
</div>
